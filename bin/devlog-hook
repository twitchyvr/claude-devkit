#!/usr/bin/env zsh
#
# devlog-hook — AI-powered development journal
#
# Runs after every git commit (via git post-commit hook).
# Uses Claude Code to generate a one-line summary and appends it to DEVLOG.md.
#
# Prerequisites: Claude Code CLI (`claude`) installed and authenticated.
#
# Usage:
#   devlog-hook              # summarize the latest commit
#   devlog-hook --install    # install as git post-commit hook in current repo
#   devlog-hook --install-global  # install globally for all repos
#

set -euo pipefail

DEVLOG_FILE="DEVLOG.md"
CLAUDE_MODEL="${CLAUDE_DEVKIT_MODEL:-haiku}"

install_hook() {
    local hooks_dir=".git/hooks"
    if [[ ! -d "$hooks_dir" ]]; then
        echo "Error: not a git repository"
        return 1
    fi

    local hook_file="$hooks_dir/post-commit"
    if [[ -f "$hook_file" ]]; then
        if grep -q "devlog-hook" "$hook_file" 2>/dev/null; then
            echo "devlog-hook already installed in this repo"
            return 0
        fi
        echo "" >> "$hook_file"
        echo "# AI devlog — auto-summarize commits" >> "$hook_file"
        echo "devlog-hook &" >> "$hook_file"
        echo "Added devlog-hook to existing post-commit hook"
    else
        cat > "$hook_file" <<'HOOK'
#!/usr/bin/env zsh
# AI devlog — auto-summarize commits
devlog-hook &
HOOK
        chmod +x "$hook_file"
        echo "Installed devlog-hook as post-commit hook"
    fi
}

install_global() {
    local template_dir="$HOME/.config/git/hooks"
    mkdir -p "$template_dir"

    local hook_file="$template_dir/post-commit"
    cat > "$hook_file" <<'HOOK'
#!/usr/bin/env zsh
# AI devlog — auto-summarize commits
devlog-hook &
HOOK
    chmod +x "$hook_file"

    git config --global core.hooksPath "$template_dir"
    echo "Installed devlog-hook globally via core.hooksPath"
    echo "All repos will now auto-generate DEVLOG.md entries"
}

summarize_commit() {
    local repo_root
    repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || return 1
    cd "$repo_root"

    # Get commit info
    local hash=$(git log -1 --format='%h')
    local date=$(git log -1 --format='%ci' | cut -c1-16)
    local author=$(git log -1 --format='%an')
    local message=$(git log -1 --format='%s')
    local diff=$(git diff HEAD~1..HEAD --stat 2>/dev/null || echo "initial commit")
    local body=$(git log -1 --format='%b' | head -5)

    # Build prompt
    local prompt="You are a development journal writer. Given this git commit, write a single concise line (max 100 chars) summarizing what was accomplished — focus on the WHY not the WHAT. No quotes, no prefix, no markdown.

Commit: $hash
Message: $message
Body: $body
Files changed:
$diff"

    # Get AI summary
    local summary
    summary=$(claude -p "$prompt" --model "$CLAUDE_MODEL" --max-turns 1 2>/dev/null \
        | sed '/^<system-reminder>/,/<\/system-reminder>/d' \
        | head -1 \
        | sed 's/^[[:space:]]*//')

    if [[ -z "$summary" ]]; then
        summary="$message"
    fi

    # Create DEVLOG.md if it doesn't exist
    if [[ ! -f "$DEVLOG_FILE" ]]; then
        cat > "$DEVLOG_FILE" <<'HEADER'
# Development Log

> Auto-generated by [devlog-hook](https://github.com/twitchyvr/claude-devkit) — AI-powered commit summaries.

HEADER
    fi

    # Append entry
    echo "- \`$date\` [\`$hash\`] $summary" >> "$DEVLOG_FILE"
}

# Main
case "${1:-}" in
    --install)
        install_hook
        ;;
    --install-global)
        install_global
        ;;
    --help|-h)
        head -14 "$0" | tail -10
        ;;
    *)
        summarize_commit
        ;;
esac
