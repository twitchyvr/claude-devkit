#!/usr/bin/env zsh
#
# ai-review — AI-powered code review from the terminal
#
# Pipes your git diff to Claude Code for an instant code review.
#
# Prerequisites: Claude Code CLI (`claude`) installed and authenticated.
#
# Usage:
#   ai-review                # review staged changes
#   ai-review HEAD~1         # review last commit
#   ai-review main           # review all changes vs main
#   ai-review --full         # review all uncommitted changes (staged + unstaged)
#

set -euo pipefail

CLAUDE_MODEL="${CLAUDE_DEVKIT_REVIEW_MODEL:-sonnet}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

get_diff() {
    local target="${1:-}"

    case "$target" in
        --full)
            git diff HEAD 2>/dev/null || git diff
            ;;
        --help|-h)
            head -15 "$0" | tail -11
            exit 0
            ;;
        "")
            local staged=$(git diff --cached --stat 2>/dev/null)
            if [[ -n "$staged" ]]; then
                echo "${DIM}Reviewing staged changes...${NC}" >&2
                git diff --cached
            else
                echo "${DIM}No staged changes. Reviewing working tree...${NC}" >&2
                git diff
            fi
            ;;
        *)
            echo "${DIM}Reviewing changes vs ${target}...${NC}" >&2
            git diff "$target"...HEAD 2>/dev/null || git diff "$target"
            ;;
    esac
}

main() {
    if ! git rev-parse --is-inside-work-tree &>/dev/null; then
        echo "${RED}Error: not in a git repository${NC}"
        exit 1
    fi

    local diff_content
    diff_content=$(get_diff "${1:-}")

    if [[ -z "$diff_content" ]]; then
        echo "${YELLOW}No changes to review.${NC}"
        exit 0
    fi

    local line_count=$(echo "$diff_content" | wc -l | tr -d ' ')

    echo "${CYAN}${BOLD}── AI Code Review ──────────────────────────${NC}"
    echo "${DIM}$line_count lines of diff · model: $CLAUDE_MODEL${NC}"
    echo ""

    local prompt="You are a senior code reviewer. Review this git diff concisely.

Format your review as:

## Summary
One sentence on what the change does.

## Issues
- 🔴 **Critical**: [if any — bugs, security issues, data loss risks]
- 🟡 **Warning**: [if any — edge cases, performance, maintainability]
- 🟢 **Suggestion**: [if any — style, naming, minor improvements]

## Verdict
One of: ✅ LGTM | ⚠️ Needs minor fixes | 🚫 Needs rework

Rules:
- Be specific — reference file names and line numbers from the diff
- Don't nitpick style unless it hurts readability
- If the diff is clean, say so briefly — don't invent problems
- Keep the entire review under 30 lines

DIFF:
$diff_content"

    claude -p "$prompt" --model "$CLAUDE_MODEL" --max-turns 1 2>/dev/null \
        | sed '/^<system-reminder>/,/<\/system-reminder>/d'

    echo ""
    echo "${DIM}── Review complete ─────────────────────────${NC}"
}

main "$@"
